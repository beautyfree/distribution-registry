{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/devall/distribution-registry/schema.json",
  "title": "Distribution Registry Node",
  "description": "A single community node — a place where AI builders post side-projects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "type",
    "name",
    "url",
    "audience_size",
    "topics",
    "post_rules",
    "post_format",
    "language",
    "last_verified_at",
    "contributor"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Registry schema version. Must be exactly 1."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Kebab-case slug. Must be unique across ALL node types."
    },
    "type": {
      "type": "string",
      "enum": [
        "telegram-chat",
        "telegram-channel",
        "subreddit",
        "discord-server",
        "slack-community",
        "directory",
        "x-person",
        "email-list"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "audience_size": {
      "type": "integer",
      "minimum": 0,
      "description": "Member/subscriber count. Use 0 if unknown — prefer honest zeros to guesses."
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "post_rules": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Summary of posting rules in the contributor's own words."
    },
    "post_format": {
      "type": "string",
      "enum": [
        "short-link",
        "manifest",
        "casual",
        "formal",
        "no-link",
        "ama-only"
      ]
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "ISO 639-1 two-letter language code."
    },
    "last_verified_at": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date (YYYY-MM-DD) when the contributor last confirmed this node is accurate."
    },
    "contributor": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9]|-(?=[a-zA-Z0-9])){0,38}$",
      "description": "GitHub handle without the @ prefix."
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "last_post_date": {
      "type": "string",
      "format": "date"
    },
    "engagement_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Optional 0-1 engagement score (posts that get replies / total posts)."
    }
  }
}
